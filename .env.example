# WHMCS API credentials. Never commit .env.
WHMCS_API_URL=https://your-whmcs.example.com
WHMCS_IDENTIFIER=
WHMCS_SECRET=
WHMCS_ACCESS_KEY=
# Timeout (ms) for all WHMCS API calls. Default: 30000
# WHMCS_TIMEOUT_MS=30000

# MCP server mode: stdio (local/Cursor) or http (deployed service)
MCP_TRANSPORT=stdio

# For HTTP mode: port and host
MCP_HTTP_PORT=3100
MCP_HTTP_HOST=0.0.0.0

# For Docker/Traefik: public hostname for MCP endpoint
WHMCS_MCP_HOST=mcp.your-domain.com

# Authentication (unified — no mode toggle needed)
# Bearer tokens always work. To also enable OAuth PKCE (Claude.ai, ChatGPT Actions),
# set MCP_OAUTH_ADMIN_PASSWORD. Without it, /authorize redirects with access_denied
# and instructions to use the auth-cli to generate a bearer token.
# Generate: openssl rand -hex 16
# MCP_OAUTH_ADMIN_PASSWORD=

# OAuth only: enable Dynamic Client Registration so Cursor/ChatGPT can self-register.
# Generate: openssl rand -hex 24. Set here and in client's Advanced OAuth settings.
# MCP_CLIENT_REGISTRATION_SECRET=
MCP_AUTH_TOKENS_FILE=/app/data/tokens.json
MCP_TOKEN_EXPIRY_DAYS=365

# Rate limiting
MCP_RATE_LIMIT_ENABLED=true
MCP_RATE_LIMIT_WINDOW_MS=60000
MCP_RATE_LIMIT_PER_IP=120
MCP_RATE_LIMIT_PER_TOKEN=300

# Security
# MCP_ALLOWED_ORIGINS: comma-separated list of allowed CORS origins for browser-based clients
# e.g. MCP_ALLOWED_ORIGINS=https://chat.openai.com,https://cursor.sh
# Default: * (allow all) — set a strict allowlist in production
MCP_ALLOWED_ORIGINS=*
MCP_TRUST_PROXY=true
# Must be true in production when TLS is at nginx/Traefik/etc. With MCP_TRUST_PROXY,
# the app enforces HTTPS and sets OAuth session cookie SameSite=None; Secure so
# cross-site consent POST (e.g. from Claude.ai) includes connect.sid.
MCP_ENFORCE_HTTPS=true

# Observability
MCP_METRICS_ENABLED=true
MCP_METRICS_PORT=9090
MCP_LOG_LEVEL=info
MCP_AUDIT_LOG_ENABLED=true
# MCP_AUDIT_LOG_FILE=/app/data/audit.log
# MCP_LOG_FILE=/app/data/app.log

# License
# Leave LICENSE_KEY blank to start a 14-day free trial.
# Purchase a license at https://daddar.io — key appears in your client portal.
LICENSE_KEY=
# Webhooks (Pro/Agency tiers — real-time event push to AI clients)
# Generate a strong random string: openssl rand -hex 32
# WHMCS_WEBHOOK_SECRET=

# Node environment
NODE_ENV=production
